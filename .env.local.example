# Required: Anthropic API key for bridging analysis
ANTHROPIC_API_KEY=sk-ant-...

# Required: Resend API key for email notifications
RESEND_API_KEY=re_...

# Required: Email address that sends notifications (must be verified in Resend)
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Public URL of the app (used for links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: path to data directory (defaults to ./data relative to project root)
DATA_DIR=./data

# Optional: max chars per participant sent to Claude per bridge call (default 8000)
BRIDGING_MAX_CHARS=8000
